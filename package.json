{
  "name": "turbo-bag-admin",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "docs:dev": "pnpm --filter @bag/docs run dev",
    "docs:build": "pnpm --filter @bag/docs run build",
    "pack:vue-bag-admin": "turbo run build --filter=vue-bag-admin && pnpm --dir packages/vue-bag-admin pack",
    "release:dry-run:vue-bag-admin": "turbo run build --filter=vue-bag-admin && pnpm --dir packages/vue-bag-admin publish --access public --dry-run",
    "release:vue-bag-admin": "turbo run build --filter=vue-bag-admin && pnpm --dir packages/vue-bag-admin publish --access public"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.3",
    "typescript": "5.9.2",
    "vite": "^6.0.0",
    "vue-tsc": "^2.1.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@vueuse/core": "^11.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,vue,json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
