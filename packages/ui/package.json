{
  "name": "@bag/ui",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "check-types": "vue-tsc -p tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "@bag/core": "^1.0.0",
    "naive-ui": "^2.40.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@bag/core": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
