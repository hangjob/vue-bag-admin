{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./dist",
    "rootDir": "./src",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@bag/core": ["../core/dist/index.d.ts"],
      "@bag/request": ["../request/dist/index.d.ts"],
      "@bag/ui": ["../ui/dist/index.d.ts"],
      "@bag/host-vue": ["../host-vue/dist/index.d.ts"]
    },
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
